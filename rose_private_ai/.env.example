APP_NAME=ROSE Private AI
APP_ENV=local
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2:3b
UPLOAD_DIR=backend/data/uploads
INDEX_PATH=backend/data/index/chunks.jsonl
AUDIT_LOG_PATH=backend/data/audit/events.jsonl
SOURCE_LEDGER_PATH=backend/data/audit/source_ledger.jsonl
CHUNK_SIZE=900
CHUNK_OVERLAP=150
DEFAULT_TOP_K=5
STRICT_SOURCE_MODE=false
REQUIRE_API_KEY=false
ROSE_API_KEY=change-me-before-network-use
MAX_UPLOAD_MB=20
LOG_FULL_PROMPTS=false
